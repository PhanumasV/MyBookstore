<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- First Category: Cookbooks -->
        <FrameLayout
            android:id="@+id/category_cookbooks"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/image_cookbooks"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/cookbooks"
                android:contentDescription="Cookbooks Image"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:text="Cookbooks"
                android:textSize="20sp"
                android:textColor="@android:color/white"
                android:background="#80000000"
                android:padding="10dp"
                android:gravity="center"/>
        </FrameLayout>

        <!-- Second Category: Humour -->
        <FrameLayout
            android:id="@+id/category_humour"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/image_humour"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/humour"
                android:contentDescription="Humour Image"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:text="Humour"
                android:textSize="20sp"
                android:textColor="@android:color/white"
                android:background="#80000000"
                android:padding="10dp"
                android:gravity="center"/>
        </FrameLayout>

        <!-- Third Category: Japanese Fiction -->
        <FrameLayout
            android:id="@+id/category_japanese_fiction"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/image_japanese_fiction"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/japanese_fiction"
                android:contentDescription="Japanese Fiction Image"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:text="Japanese Fiction"
                android:textSize="20sp"
                android:textColor="@android:color/white"
                android:background="#80000000"
                android:padding="10dp"
                android:gravity="center"/>
        </FrameLayout>

        <!-- Fourth Category: Manga -->
        <FrameLayout
            android:id="@+id/category_manga"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/image_manga"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/manga"
                android:contentDescription="Manga Image"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:text="Manga"
                android:textSize="20sp"
                android:textColor="@android:color/white"
                android:background="#80000000"
                android:padding="10dp"
                android:gravity="center"/>
        </FrameLayout>

    </LinearLayout>
</ScrollView>
