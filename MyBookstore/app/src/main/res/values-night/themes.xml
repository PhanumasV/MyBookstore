<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Parent Theme: Use a Material Dark Mode Theme -->
    <style name="Theme.MyBookStore" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary Color -->
        <item name="colorPrimary">@color/primaryColor</item>

        <!-- Window Background for Dark Mode -->
        <item name="android:windowBackground">@color/black</item>

        <!-- Set default text color to white for dark mode -->
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">@android:color/white</item>

        <!-- Set toolbar text color (optional) -->
        <item name="colorOnPrimary">@android:color/white</item>

        <!-- Button Text Color -->
        <item name="colorOnSurface">@android:color/white</item>

        <!-- Adjust background and surface colors to match dark mode better -->
        <item name="android:background">@color/black</item>
        <item name="android:colorBackgroundFloating">@color/black</item>
        <item name="colorSurface">@color/black</item>


        <!-- Adjust other UI components like the status bar and navigation bar -->
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>

        <!-- Set the text color of other important UI elements -->
       <!-- <item name="android:textColor">@android:color/white</item> -->

        <!-- Text Color for EditText Fields -->
        <item name="android:textColorHint">@android:color/darker_gray</item>
        <item name="android:textColor">@android:color/darker_gray</item>

    </style>
</resources>
